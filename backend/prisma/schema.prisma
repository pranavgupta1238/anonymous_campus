// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum Orientation {
  STRAIGHT
  GAY
  LESBIAN
  BISEXUAL
}

enum RequestStatus {
  OPEN
  MATCHED
  CANCELLED
  EXPIRED
}

enum OutingCategory {
  COFFEE
  MOVIE
  SPORTS
  SHOPPING
  EVENT
  EXPLORING
  OTHER
}

enum ConversationType {
  CAMPUS
  PRIVATE
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum AttachmentType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum AttachmentModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ReportReason {
  HARASSMENT
  SPAM
  INAPPROPRIATE_CONTENT
  THREATS
  FAKE_PROFILE
  OTHER
}

enum InterestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ReportTargetType {
  USER
  MESSAGE
  ATTACHMENT
}

enum ReportOutcome {
  PENDING
  VALID
  INVALID
}

model University {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users User[]

  domains UniversityDomain[]

  conversations Conversation[]
}

model UniversityDomain {
  id     String @id @default(cuid())
  domain String @unique

  universityId String

  university University @relation(fields: [universityId], references: [id])
}

model Avatar {
  id String @id @default(cuid())

  name String

  imageUrl String

  isActive Boolean @default(true)

  users User[]
}

model User {
  id String @id @default(cuid())

  email String @unique

  publicUsername String @unique

  gender Gender

  orientation Orientation

  availableThisWeekend Boolean @default(false)

  lookingForRelationship Boolean @default(false)

  profileCompleted Boolean @default(false)

  reputationScore Float @default(5.0)

  successfulOutings Int @default(0)

  noShowCount Int @default(0)

  reportsCount Int @default(0)

  isVerified Boolean @default(false)

  verifiedAt DateTime?

  readReceiptsEnabled Boolean @default(true)

  isSuspended Boolean @default(false)

  suspendedUntil DateTime?

  isBanned Boolean @default(false)

  avatarId String?

  universityId String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  lastActiveAt DateTime @default(now())

  avatar Avatar? @relation(fields: [avatarId], references: [id])

  university University @relation(fields: [universityId], references: [id])

  usernameHistory UsernameHistory[]

  conversationParticipants ConversationParticipant[]

  messages Message[]

  messageReceipts MessageReceipt[]

  attachments Attachment[]

  blocksGiven UserBlock[] @relation("UserBlocksGiven")

  blocksReceived UserBlock[] @relation("UserBlocksReceived")

  reportsCreated Report[] @relation("ReportsCreated")

  reportsReceived Report[] @relation("ReportsReceived")

  outingInterestsSent OutingInterest[] @relation("OutingInterestsSent")

  outingInterestsReceived OutingInterest[] @relation("OutingInterestsReceived")

  outingMatchesAsUser1 OutingMatch[] @relation("OutingMatchUser1")

  outingMatchesAsUser2 OutingMatch[] @relation("OutingMatchUser2")

  @@index([universityId])
  @@index([gender])
  @@index([orientation])
  @@index([avatarId])
}

model UsernameHistory {
  id String @id @default(cuid())

  userId String

  oldUsername String

  newUsername String

  changedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Conversation {
  id String @id @default(cuid())

  type ConversationType

  universityId String?

  outingMatch OutingMatch?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  university University? @relation(fields: [universityId], references: [id])

  participants ConversationParticipant[]

  messages Message[]

  @@index([universityId])
}

model ConversationParticipant {
  id String @id @default(cuid())

  conversationId String

  userId String

  joinedAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  user User @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id String @id @default(cuid())

  conversationId String

  senderId String

  senderUsername String

  content String @db.Text

  isDeleted Boolean @default(false)

  isFlagged Boolean @default(false)

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  sender User @relation(fields: [senderId], references: [id])

  receipts MessageReceipt[]

  attachments Attachment[]

  reports Report[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model MessageReceipt {
  id String @id @default(cuid())

  messageId String

  recipientId String

  status MessageStatus @default(SENT)

  deliveredAt DateTime?

  readAt DateTime?

  message Message @relation(fields: [messageId], references: [id])

  recipient User @relation(fields: [recipientId], references: [id])

  @@unique([messageId, recipientId])
  @@index([recipientId])
}

model Attachment {
  id String @id @default(cuid())

  messageId String

  uploaderId String

  fileUrl String

  fileName String

  fileType AttachmentType

  mimeType String

  fileSize Int

  blurHash String?

  moderationStatus AttachmentModerationStatus @default(PENDING)

  moderationReason String?

  nudityDetected Boolean @default(false)

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])

  uploader User @relation(fields: [uploaderId], references: [id])

  reports Report[]

  @@index([messageId])
  @@index([uploaderId])
  @@index([moderationStatus])
}

model UserBlock {
  id String @id @default(cuid())

  blockerId String

  blockedUserId String

  createdAt DateTime @default(now())

  blocker User @relation("UserBlocksGiven", fields: [blockerId], references: [id])

  blockedUser User @relation("UserBlocksReceived", fields: [blockedUserId], references: [id])

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
}

model Report {
  id String @id @default(cuid())

  reporterId String

  targetType ReportTargetType

  reportedUserId String?

  reportedMessageId String?

  reportedAttachmentId String?

  reason ReportReason

  description String? @db.Text

  status ReportStatus @default(PENDING)

  outcome ReportOutcome @default(PENDING)

  moderationNotes String? @db.Text

  reviewedAt DateTime?

  createdAt DateTime @default(now())

  reporter User @relation("ReportsCreated", fields: [reporterId], references: [id])

  reportedUser User? @relation("ReportsReceived", fields: [reportedUserId], references: [id])

  reportedMessage Message? @relation(fields: [reportedMessageId], references: [id])

  reportedAttachment Attachment? @relation(fields: [reportedAttachmentId], references: [id])

  @@index([reporterId])

  @@index([status])

  @@index([outcome])

  @@index([targetType])

  @@index([reportedUserId])

  @@index([reportedMessageId])

  @@index([reportedAttachmentId])
}

model VerificationToken {
  id String @id @default(cuid())

  email String

  token String

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model OutingInterest {
  id String @id @default(cuid())

  senderId String

  receiverId String

  status InterestStatus @default(PENDING)

  createdAt DateTime @default(now())

  sender User @relation("OutingInterestsSent", fields: [senderId], references: [id])

  receiver User @relation("OutingInterestsReceived", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model OutingMatch {
  id String @id @default(cuid())

  user1Id String

  user2Id String

  conversationId String @unique

  matchedAt DateTime @default(now())

  completedAt DateTime?

  user1 User @relation("OutingMatchUser1", fields: [user1Id], references: [id])

  user2 User @relation("OutingMatchUser2", fields: [user2Id], references: [id])

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([user1Id])
  @@index([user2Id])
}
