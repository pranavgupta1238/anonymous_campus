// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum Orientation {
  STRAIGHT
  GAY
  LESBIAN
  BISEXUAL
}

enum RequestStatus {
  OPEN
  MATCHED
  CANCELLED
  EXPIRED
}

enum OutingCategory {
  COFFEE
  MOVIE
  SPORTS
  SHOPPING
  EVENT
  EXPLORING
  OTHER
}

enum ConversationType {
  CAMPUS
  PRIVATE
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum AttachmentType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum AttachmentModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model University {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users User[]

  domains UniversityDomain[]

  conversations Conversation[]
}

model UniversityDomain {
  id     String @id @default(cuid())
  domain String @unique

  universityId String

  university University @relation(fields: [universityId], references: [id])
}

model Avatar {
  id String @id @default(cuid())

  name String

  imageUrl String

  users User[]
}

model User {
  id String @id @default(cuid())

  email String @unique

  publicUsername String @unique

  gender Gender

  orientation Orientation

  availableThisWeekend Boolean @default(false)

  lookingForRelationship Boolean @default(false)

  profileCompleted Boolean @default(false)

  reputationScore Float @default(5.0)

  successfulOutings Int @default(0)

  noShowCount Int @default(0)

  reportsCount Int @default(0)

  isVerified Boolean @default(false)

  verifiedAt DateTime?

  readReceiptsEnabled Boolean @default(true)

  isSuspended Boolean @default(false)

  isBanned Boolean @default(false)

  avatarId String?

  universityId String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  lastActiveAt DateTime @default(now())

  avatar Avatar? @relation(fields: [avatarId], references: [id])

  university University @relation(fields: [universityId], references: [id])

  usernameHistory UsernameHistory[]

  conversationParticipants ConversationParticipant[]

  messages Message[]

  messageReceipts MessageReceipt[]

  attachments Attachment[]

  @@index([universityId])
  @@index([gender])
  @@index([orientation])
  @@index([avatarId])
}

model UsernameHistory {
  id String @id @default(cuid())

  userId String

  oldUsername String

  changedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Conversation {
  id String @id @default(cuid())

  type ConversationType

  universityId String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  university University? @relation(fields: [universityId], references: [id])

  participants ConversationParticipant[]

  messages Message[]

  @@index([universityId])
}

model ConversationParticipant {
  id String @id @default(cuid())

  conversationId String

  userId String

  joinedAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  user User @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id String @id @default(cuid())

  conversationId String

  senderId String

  senderUsername String

  content String @db.Text

  isDeleted Boolean @default(false)

  isFlagged Boolean @default(false)

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  sender User @relation(fields: [senderId], references: [id])

  receipts MessageReceipt[]

  attachments Attachment[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model MessageReceipt {
  id String @id @default(cuid())

  messageId String

  recipientId String

  status MessageStatus @default(SENT)

  deliveredAt DateTime?

  readAt DateTime?

  message Message @relation(fields: [messageId], references: [id])

  recipient User @relation(fields: [recipientId], references: [id])

  @@unique([messageId, recipientId])
  @@index([recipientId])
}

model Attachment {
  id String @id @default(cuid())

  messageId String

  uploaderId String

  fileUrl String

  fileName String

  fileType AttachmentType

  fileSize Int

  blurHash String?

  moderationStatus AttachmentModerationStatus @default(PENDING)

  moderationReason String?

  nudityDetected Boolean @default(false)

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])

  uploader User @relation(fields: [uploaderId], references: [id])

  @@index([messageId])
  @@index([uploaderId])
  @@index([moderationStatus])
}
